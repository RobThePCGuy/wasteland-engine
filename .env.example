# GEMINI_API_KEY: Required for Gemini AI API calls.
# Get yours at https://aistudio.google.com/app/apikey
# NOTE: This key is currently exposed to the client bundle via vite.config.ts.
# For production, route all Gemini calls through the server instead.
GEMINI_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="http://localhost:5173"

# JWT_SECRET: Secret key for signing JWT authentication tokens.
# Generate a strong random string (e.g. openssl rand -base64 32).
JWT_SECRET=""
